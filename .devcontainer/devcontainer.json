{
  "name": "Linux Workspace",

  "build": {
    "dockerfile": "Dockerfile"
  },

  "remoteUser": "vscode",

  "postCreateCommand": "bash install.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-python.python",
        "james-yu.latex-workshop"
      ],

      "settings": {
        "terminal.integrated.defaultProfile.linux": "fish",
        "latex-workshop.latex.autoBuild.run": "onSave",
        "latex-workshop.view.pdf.viewer": "tab"
      }
    },

    "codespaces": {
      "repositories": {
        "Bigmac010/a": {
          "permissions": {
            "contents": "write"
          }
        }
      }
    },

    "codespaces": {
      "repositories": {
        "Bigmac010/BMO": {
          "permissions": {
            "contents": "write"
          }
        }
      }
    },

    "codespaces": {
      "repositories": {
        "Bigmac010/Misc": {
          "permissions": {
            "contents": "write"
          }
        }
      }
    }

  }
}
